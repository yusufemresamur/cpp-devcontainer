{
    "name": "dev-${localEnv:USER}",
    "build": {
        "context": ".",
        "dockerfile": "./Dockerfile",
        "args": {
            "USERNAME": "${localEnv:USER}",
            "LLVM_VERSION":"20",
            "BAZELISK_VERSION":"1.28.1",
            "BUILDIFIER_VERSION":"8.5.1"
        },
        "options": ["--network=host"]
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "bazelbuild.vscode-bazel"
            ],
            "settings": {
                "dev.containers.mountWaylandSocket": false
            }
        }
    },
    "privileged": true,
    "initializeCommand":"bash .devcontainer/cpp-devcontainer/pre-init.sh",
    "postStartCommand": "bash .devcontainer/cpp-devcontainer/entrypoint.sh",
    "mounts": [
        {
            "source": "${localEnv:HOME}/.bash_history",
            "target": "${localEnv:HOME}/.bash_history",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}/.cache",
            "target": "${localEnv:HOME}/.cache",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}/.netrc",
            "target": "${localEnv:HOME}/.netrc",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}/.gitconfig",
            "target": "${localEnv:HOME}/.gitconfig",
            "type": "bind"
        }

    ],
    "updateRemoteUserUID": false,
    "runArgs": [
        "--network=host"
    ]
}